# ====== Namuna konfiguratsiya. Haqiqiy sirlarni shu yerga YOZMANG. ======
# Bu faylni nusxalab `.env` yarating va qiymatlarni to'ldiring.
# `.env` git'ga TUSHMAYDI (.gitignore'da). Production sirlarini secret-store/vault orqali bering.

# Production'da DEBUG=false bo'lishi SHART (aks holda stack-trace va DB ma'lumotlari sizadi)
DEBUG=false

# PostgreSQL ulanishi
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/DBNAME

# JWT sirlari — har biri MUSTAQIL va yuqori entropiyali bo'lsin:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_ACCESS_SECRET=CHANGE_ME_unique_random_64_bytes
JWT_REFRESH_SECRET=CHANGE_ME_different_unique_random_64_bytes

# NFC reader (turniket/eshik) qurilmasi uchun maxfiy kalit. O'rnatilmasa, /attendance/nfc
# o'chiq bo'ladi (503). Qurilma har so'rovda X-NFC-Device-Key header'ida shu kalitni yuboradi.
#   python -c "import secrets; print(secrets.token_hex(32))"
NFC_DEVICE_API_KEY=CHANGE_ME_nfc_device_secret

# Boshlang'ich superuser (faqat birinchi seed uchun). Kuchli parol qo'ying.
SUPERUSER_USERNAME=admin
SUPERUSER_PASSWORD=CHANGE_ME_strong_password
SUPERUSER_FIRSTNAME=Ism
SUPERUSER_LASTNAME=Familiya
SUPERUSER_PHONE=+998000000000

# Ixtiyoriy: CORS / Trusted hostlarni override qilish (production domenlari)
# CORS_ORIGINS=["https://hr.dunyosupermarket.uz"]
# ALLOWED_HOSTS=["api.dunyosupermarket.uz"]

# YesPOS integratsiya (kalitni hech qachon commit qilmang)
YESPOS_URL=
