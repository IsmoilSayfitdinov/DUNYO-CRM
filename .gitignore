# ============================================================
#  DUNYO CRM — monorepo .gitignore
#  (server/ — FastAPI · client/ — React/Vite · mobile/)
# ============================================================

# ---------- Maxfiy ma'lumotlar (HECH QACHON commit qilinmasin) ----------
# Muhit o'zgaruvchilari — .env.example tracked, qolgani yo'q
.env
.env.*
!.env.example

# TLS / SSL sertifikat va kalitlar
certs/
*.pem
*.key
*.crt
*.p12
*.pfx

# Boshqa sirlar
*.secret
secrets.*

# ---------- Node / Frontend (client/) ----------
node_modules/
dist/
dev-dist/
.vite/
*.local

# npm / yarn / pnpm / bun loglari
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------- Python / Backend (server/) ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual muhitlar
.venv/
venv/
env/
ENV/

# Build / paket artefaktlari
build/
*.egg-info/
.eggs/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# ---------- Ma'lumotlar bazasi (lokal) ----------
*.db
*.sqlite
*.sqlite3

# ---------- Loglar ----------
*.log
logs/

# ---------- Muharrir / IDE ----------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------- OS ----------
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
